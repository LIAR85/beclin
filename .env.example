# ─────────────────────────────────────────────────────────────
#  Be Clean PWA — Variables de entorno
#  Copia los valores desde: https://supabase.com/dashboard
#  Tu proyecto → Settings → API
# ─────────────────────────────────────────────────────────────

# URL del proyecto Supabase
# Ejemplo: https://abcdefghijklmnop.supabase.co
# Dónde encontrarlo: Settings → API → Project URL
VITE_SUPABASE_URL=https://pnsvcbtznmkkafkymgvk.supabase.co

# Clave pública anónima (anon key) — segura para exponer en el frontend
# Ejemplo: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Dónde encontrarlo: Settings → API → Project API keys → anon public
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBuc3ZjYnR6bm1ra2Fma3ltZ3ZrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI3NTIzNTUsImV4cCI6MjA5ODMyODM1NX0.TsXiRF7DQLSzCmj10gOaYdhqjZj9EDKf7fr205AkHA4

# ─────────────────────────────────────────────────────────────
#  Las dos variables de abajo son para el script de keepalive
#  (scripts/supabase-keepalive.mjs y GitHub Actions)
#  Son los mismos valores que arriba — solo cópialos igual
# ─────────────────────────────────────────────────────────────

# Mismo valor que VITE_SUPABASE_URL
SUPABASE_PROJECT_URL=https://pnsvcbtznmkkafkymgvk.supabase.co

# Mismo valor que VITE_SUPABASE_ANON_KEY
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBuc3ZjYnR6bm1ra2Fma3ltZ3ZrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI3NTIzNTUsImV4cCI6MjA5ODMyODM1NX0.TsXiRF7DQLSzCmj10gOaYdhqjZj9EDKf7fr205AkHA4